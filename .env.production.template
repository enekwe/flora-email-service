# Flora Email Service - Production Environment Variables
# Copy to Railway Dashboard → flora-email-service → Variables

# ============================================
# SERVICE CONFIGURATION
# ============================================
NODE_ENV=production
PORT=3016
SERVICE_NAME=flora-email-service
LOG_LEVEL=info
ENABLE_AUDIT_LOGGING=true

# ============================================
# DATABASE CONFIGURATION
# ============================================
# CRITICAL: Get from Railway MongoDB service or use shared database
# Format: mongodb://user:password@host:port/database?authSource=admin
MONGODB_URI=<REQUIRED - Get from Railway MongoDB service>

# ============================================
# JWT AUTHENTICATION
# ============================================
# CRITICAL: Must match main app JWT_SECRET
JWT_SECRET=<REQUIRED - Copy from passbook-flora service>
JWT_EXPIRES_IN=7d

# ============================================
# EMAIL SERVICE (BREVO)
# ============================================
# CRITICAL: Get from passbook-flora service
BREVO_API_KEY=<REQUIRED - Copy from passbook-flora service>
BREVO_API_URL=https://api.brevo.com/v3
BREVO_SENDER_EMAIL=flora@passbook.vc
BREVO_SENDER_NAME=Passbook Flora

# ============================================
# SERVICE-TO-SERVICE AUTHENTICATION
# ============================================
# CRITICAL: Must match between services
# Main app uses this to authenticate requests to email service
MAIN_APP_API_KEY=<REQUIRED - Copy from passbook-flora INVITATIONS_SERVICE_API_KEY>

# ============================================
# EXTERNAL SERVICE URLS
# ============================================
FRONTEND_URL=https://flora.passbook.vc
MAIN_APP_API_URL=https://api.flora.passbook.vc

# ============================================
# RATE LIMITING & SECURITY
# ============================================
MAX_INVITATIONS_PER_HOUR=100
TOKEN_EXPIRATION_DAYS=7

# ============================================
# CORS CONFIGURATION
# ============================================
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=https://flora.passbook.vc,https://api.flora.passbook.vc

# ============================================
# MONITORING & LOGGING
# ============================================
# Optional: Configure external logging/monitoring services
# SENTRY_DSN=<optional>
# DATADOG_API_KEY=<optional>
# NEW_RELIC_LICENSE_KEY=<optional>

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_INVITATION_EMAILS=true
ENABLE_AUTH_EMAILS=true
ENABLE_CAPITAL_CALL_EMAILS=true
ENABLE_DOCUMENT_EMAILS=true
ENABLE_NOTIFICATION_EMAILS=true

# ============================================
# EMAIL TEMPLATE CONFIGURATION
# ============================================
# Template IDs from Brevo dashboard (if using Brevo templates instead of local)
# BREVO_TEMPLATE_GP_INVITATION=<optional>
# BREVO_TEMPLATE_LP_INVITATION=<optional>
# BREVO_TEMPLATE_FOUNDER_INVITATION=<optional>
# BREVO_TEMPLATE_ADMIN_INVITATION=<optional>

# ============================================
# NOTES
# ============================================
# 1. All REQUIRED variables must be set before deployment
# 2. Copy sensitive values from passbook-flora service in Railway
# 3. Never commit actual values to git
# 4. Test with health endpoint: GET /health
